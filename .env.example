# ─── Go Job Scheduler — Example environment ────────────────────────────────
# Copy to `.env` for local development:
#   cp .env.example .env
#
# In production, set these via your orchestrator (Kubernetes, systemd, etc.)
# rather than relying on a .env file.

# Runtime environment: development | staging | production
# Affects log defaults and other dev-vs-prod toggles.
ENVIRONMENT=development

# HTTP server port (1..65535)
HTTP_PORT=8080

# Postgres connection string. REQUIRED — no default.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/scheduler?sslmode=disable

# Minimum log level: debug | info | warn | error
LOG_LEVEL=info

# Log output format: json (production) | text (development, human-friendly)
LOG_FORMAT=text

# Number of concurrent worker goroutines processing jobs.
WORKER_COUNT=8

# Graceful shutdown timeout. Accepts Go duration syntax (e.g. 30s, 1m, 2m30s).
SHUTDOWN_TIMEOUT=30s
